    },
    "selectPrintPhotos":  {
      "entry": ["transition"],
      "meta": { 
        "path": "/select-print-photos", 
        "assets": { 
            "assetButtonPlus": "{{{assets.selectPrintPhotos.assetButtonPlus}}}", 
            "assetButtonMinus": "{{{assets.selectPrintPhotos.assetButtonMinus}}}",
            "assetButtonPrinter": "{{{assets.selectPrintPhotos.assetButtonPrinter}}}",
            "maxNumberOfPrints": "{{{maxNumberOfPrints}}}"
        }
      },
      "on": {
        "event.select-print-photos.01": { 
          "target": "mirrorWillPrintPhotos",
          "actions":  "printPhoto"
        }
      }
    },
    "mirrorWillPrintPhotos": {
      "entry": ["transition"],
      "meta": { 
        "path": "/anim1/7", 
        "assets": {
            "assetPath": "{{{assets.mirrorWillPrintPhotos}}}"
        } 
      },
      "initial": "anim_loaded",
      "states": {
          "anim_loaded": {
              "on": {
                  "event.anim1.01": {
                      "target": "anim_running"
                  }           
              }
          },
          "anim_running": {
              "after": {
                  "FINISH_ANIM": "#root.infoPage"
              }
          }
      }
    },
    "infoPage": {
      "entry": ["transition"],
      "meta": { 
        "path": "/info",
        "assets": { 
            "assetButtonOkPath": "{{{assets.infoPage.assetButtonOkPath}}}",
            "brochureImage": "{{{assets.infoPage.brochureImage}}}",
            "galleryCode": "{{{event_id}}}"           
        } 
      },
      "on": {
        "event.info-page.01": "intro"
      }
    },
    "errorPage": {
      "entry": ["transition"],
      "meta": { 
        "path": "/error",
        "assets": { 
            "assetButtonHome": "{{{assets.errorPage.assetButtonHome}}}",
            "phoneNumber": "{{{phone_number}}}"           
        } 
      },
      "on": {
        "event.error-page.01": "intro"
      }
    }     
  }
}