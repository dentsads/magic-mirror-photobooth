{
  "id": "root",
  "initial": "intro",
  "context": {
    "capturedPhotoPaths": [],
    "exifOrientation": 1,
    "capturedPhotoFile": "",
    "photoPath": "",
    "maxNumberOfPrints": {{{maxNumberOfPrints}}},
    "maxNumberOfPhotos": {{{maxNumberOfPhotos}}},
    "compositeConfig": {
        "templateLayout": "{{{assets.compositePhoto.compositeConfig.templateLayout}}}",                                
        "overlayImage": "{{{assets.compositePhoto.compositeConfig.overlayImage}}}",
        "logoImage": "{{{assets.compositePhoto.compositeConfig.logoImage}}}",
        "logoImageOffset": "{{{assets.compositePhoto.compositeConfig.logoImageOffset}}}",
        "logoImageSize": "{{{assets.compositePhoto.compositeConfig.logoImageSize}}}",
        "overlayText": "{{{assets.compositePhoto.compositeConfig.overlayText}}}",
        "overlayTextSize": "{{{assets.compositePhoto.compositeConfig.overlayTextSize}}}",
        "overlayTextOffset": "{{{assets.compositePhoto.compositeConfig.overlayTextOffset}}}"
    }
    {{#assets.triggerLed.ball}},
    "triggerLedConfig": {
        "animationType": "ball",
        "direction": "{{{assets.triggerLed.ball.direction}}}",
        "color": "{{{assets.triggerLed.ball.color}}}",
        "loops": {{{assets.triggerLed.ball.loops}}}
    }
    {{/assets.triggerLed.ball}}
    {{#assets.triggerLed.barrel}},
    "triggerLedConfig": {
        "animationType": "barrel",
        "direction": "{{{assets.triggerLed.barrel.direction}}}",
        "color": "{{{assets.triggerLed.barrel.color}}}",
        "shiftDelay": {{{assets.triggerLed.barrel.shiftDelay}}}
    }
    {{/assets.triggerLed.barrel}}
  },
  "states": {
    "intro": {
      "entry": ["transition"],
      "meta": { 
        "path": "/intro", 
        "assets": {
            "assetPath": "{{{assets.intro}}}",
            "website": "{{{website}}}"
        }
      },
      "on": {
        "event.intro.01": {
          "target": "mirrotWillTakePhotos"
        }
      }
    },
    "mirrotWillTakePhotos": {
      "entry": ["transition"],
      "meta": { 
        "path": "/anim1/6", 
        "assets": {
            "assetPath": "{{{assets.mirrotWillTakePhotos}}}"
        } 
      },
      "initial": "anim_loaded",
      "states": {
          "anim_loaded": {
              "on": {
                  "event.anim1.01": {
                      "target": "anim_running"
                  }           
              }
          },
          "anim_running": {
              "after": {
                  "FINISH_ANIM": "#root.countdown"
              }
          }
      }
    },
    "countdown": {
      "entry": ["transition"],
      "meta": { 
        "path": "/anim1/3", 
        "assets": {
            "assetPath": "{{{assets.countdown}}}",
            "website": "{{{website}}}"
        } 
      },
      "initial": "anim_loaded",
      "states": {
          "anim_loaded": {
              "on": {
                  "event.anim1.01": {
                      "target": "anim_running"
                  }           
              }
          },
          "anim_running": {
              "after": {
                  "FINISH_ANIM": "#root.lookAtCamera"
              }
          }
      }
    },
    "lookAtCamera": {
      "entry": ["transition"],
      "meta": { 
        "path": "/anim1/8", 
        "assets": {
            "assetPath": "{{{assets.lookAtCamera}}}"
        } 
      },
      "initial": "anim_loaded",
      "states": {
          "anim_loaded": {
              "on": {
                  "event.anim1.01": {
                      "target": "anim_running",
                      "actions": "triggerLed"
                  }           
              }
          },
          "anim_running": {
              "after": {
                  "FINISH_ANIM": "#root.clearLed"
              }
          }
      }
    },
    "clearLed": {
      "meta": {},
      "invoke": {
        "id": "clear",
        "src": "clearLed",
        "onDone": {
          "target": "capturePhoto",
          "actions": "logClearLed"
        },
        "onError": {
          "target": "capturePhoto",
          "actions": "logError"
        }              
      }
    },        
    "capturePhoto": {
      "meta": {},
      "invoke": {
        "id": "capture",
        "src": "capturePhoto",
        "onDone": {
          "target": "acceptPhoto",
          "actions": "setCapturedPhoto"
        },
        "onError": {
          "target": "errorPage",
          "actions": "logError"
        }              
      }
    },
