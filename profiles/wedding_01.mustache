{
    "id": "root",
    "initial": "intro",
    "context": {
      "capturedPhotoPaths": [],
      "exifOrientation": 1,
      "photoPath": "",
      "maxNumberOfPhotos": {{{maxNumberOfPhotos}}}
    },
    "states": {
      "intro": {
        "entry": ["transition"],
        "meta": { 
          "path": "/intro", 
          "assets": {
              "assetPath": "{{{theme.assets.intro.assetPath}}}",
              "website": "{{{website}}}"
          }
        },
        "on": {
          "event.intro.01": {
            "target": "countdown"
          }
        }
      },
      "countdown": {
        "entry": ["transition"],
        "meta": { 
          "path": "/anim1/3", 
          "assets": {
              "assetPath": "{{{theme.assets.countdown}}}",
              "website": "{{{website}}}"
          } 
        },
        "initial": "anim_loaded",
        "states": {
            "anim_loaded": {
                "on": {
                    "event.anim1.01": {
                        "target": "anim_running",
                        "actions": "triggerLed"
                    }           
                }
            },
            "anim_running": {
                "after": {
                    "FINISH_ANIM": "#root.clearLed"
                }
            }
        }
      },
      "clearLed": {
        "invoke": {
          "id": "clear",
          "src": "clearLed",
          "onDone": {
            "target": "capturePhoto",
            "actions": "logClearLed"
          },
          "onError": {
            "target": "capturePhoto",
            "actions": "logError"
          }              
        }
      },
      "capturePhoto": {
        "invoke": {
          "id": "capture",
          "src": "capturePhoto",
          "onDone": {
            "target": "acceptPhoto",
            "actions": "setCapturedPhoto"
          },
          "onError": {
            "target": "errorPage",
            "actions": "logError"
          }              
        }
      },
      "acceptPhoto":  {
        "entry": ["updateMetaAssetsWithContext", "transition"],
        "meta": { 
          "path": "/accept-photo", 
          "assets": { 
              "assetButtonOkPath": "{{{theme.assets.acceptPhoto.assetButtonOkPath}}}", 
              "assetButtonNokPath": "{{{theme.assets.acceptPhoto.assetButtonNokPath}}}"
          }
        },
        "on": {
          "event.accept-photo.01": [
            { "target": "drawing", "cond": "targetNumberOfPhotosReached" },
            { "target": "countdown"}
          ],
          "event.accept-photo.02": {
            "target": "countdown",
            "actions": "popCapturedPhotos"
          }
        }
      },
      "drawing":  {
        "entry": ["transition"],
        "meta": { 
          "path": "/drawing", 
          "assets": { 
              "assetButtonClear": "{{{theme.assets.drawing.assetButtonClear}}}", 
              "assetButtonOk": "{{{theme.assets.drawing.assetButtonOk}}}",
              "assetButtonColor": "{{{theme.assets.drawing.assetButtonColor}}}"
          }
        },
        "on": {
          "event.drawing-tool.01": "compositePhoto"
        }
      },
      "compositePhoto": {
        "entry": ["transition"],
        "meta": { "path": "/anim1/6", "assets": "{{{theme.assets.compositePhoto}}}" },
        "invoke": {
          "id": "composite",
          "src": "compositePhoto",
          "onDone": {
            "target": "acceptCompositedPhoto",
            "actions": "clearCapturedPhotos"
          },
          "onError": {
            "target": "errorPage",
            "actions": "logError"
          }
        }
      },
      "acceptCompositedPhoto":  {
        "entry": ["transition", "updateMetaAssetsWithContext"],
        "meta": { 
          "path": "/accept-photo", 
          "assets": { 
              "assetButtonOkPath": "{{{theme.assets.acceptCompositedPhoto.assetButtonOkPath}}}", 
              "assetButtonNokPath": "{{{theme.assets.acceptCompositedPhoto.assetButtonNokPath}}}"                
          }
        },
        "on": {
          "event.accept-photo.01": "selectPrintPhotos",
          "event.accept-photo.02": "countdown"
        }
      },
      "selectPrintPhotos":  {
        "entry": ["transition"],
        "meta": { 
          "path": "/select-print-photos", 
          "assets": { 
              "assetButtonPlus": "{{{theme.assets.selectPrintPhotos.assetButtonPlus}}}", 
              "assetButtonMinus": "{{{theme.assets.selectPrintPhotos.assetButtonMinus}}}",
              "assetButtonPrinter": "{{{theme.assets.selectPrintPhotos.assetButtonPrinter}}}"
          }
        },
        "on": {
          "event.select-print-photos.01": "printPhoto"
        }
      },
      "printPhoto": {
        "invoke": {
          "id": "print",
          "src": "printPhoto",
          "onDone": {
            "target": "intro",
            "actions": "logStatus"
          },
          "onError": {
            "target": "errorPage",
            "actions": "logError"
          }              
        }
      },
      "errorPage": {
        "entry": ["transition"],
        "meta": { 
          "path": "/error",
          "assets": { 
              "assetButtonHome": "{{{theme.assets.errorPage.assetButtonHome}}}",
              "phoneNumber": "{{{phone_number}}}"           
          } 
        },
        "on": {
          "event.error-page.01": "intro"
        }
      }     
    }
  }