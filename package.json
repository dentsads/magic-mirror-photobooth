{
  "name": "magic-mirror-photobooth",
  "version": "0.4.0",
  "description": "Software for an interactive magic mirror photobooth",
  "scripts": {
    "ng": "ng",
    "start:client": "ng serve --proxy-config proxy.conf.json",
    "start:server": "node built/server/server.js",
    "serve:dev": "concurrently \"npm run start:client\" \"npm run start:server\"",
    "serve:prod": "npm run start:client && npm run start:server",
    "build:server": "tsc --build tsconfig.server.json",
    "build:client": "ng build",
    "build": "npm run build:client && npm run build:server",
    "clean": "rm -rf ./built && rm -rf ./dist",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/d.dentsas/magic-mirror-photobooth"
  },
  "bugs": {
    "url": "https://gitlab.com/d.dentsas/magic-mirror-photobooth/issues"
  },
  "keywords": [
    "magic-mirror",
    "photobooth",
    "photobox"
  ],
  "author": "Dimitrios Dentsas",
  "private": true,
  "dependencies": {
    "@angular/animations": "11.0.5",
    "@angular/common": "11.0.5",
    "@angular/compiler": "11.0.5",
    "@angular/core": "11.0.5",
    "@angular/forms": "11.0.5",
    "@angular/platform-browser": "11.0.5",
    "@angular/platform-browser-dynamic": "11.0.5",
    "@angular/router": "11.0.5",
    "@dagrejs/graphlib": "2.1.4",
    "@simonwep/pickr": "1.8.0",
    "@types/express": "4.17.9",
    "axios": "0.21.1",
    "concurrently": "5.3.0",
    "express": "4.17.1",
    "fabric": "4.3.0",
    "gphoto2": "0.3.2",
    "johnny-five": "2.0.0",
    "mustache": "^4.1.0",
    "node-pixel": "0.11.0",
    "qrcode": "1.4.4",
    "rxjs": "6.6.3",
    "ts-node-dev": "1.1.1",
    "tslib": "2.0.3",
    "uuid": "8.3.2",
    "winston": "3.3.3",
    "winston-daily-rotate-file": "4.5.0",
    "xstate": "4.15.2",
    "zone.js": "^0.10.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^0.1100.5",
    "@angular/cli": "11.0.5",
    "@angular/compiler-cli": "^11.0.5",
    "@angular/language-service": "11.0.5",
    "@types/jasmine": "3.6.2",
    "@types/jasminewd2": "2.0.8",
    "@types/node": "14.14.16",
    "codelyzer": "6.0.1",
    "jasmine-core": "3.6.0",
    "jasmine-spec-reporter": "6.0.0",
    "karma": "5.2.3",
    "karma-chrome-launcher": "3.1.0",
    "karma-coverage-istanbul-reporter": "3.0.3",
    "karma-jasmine": "4.0.1",
    "karma-jasmine-html-reporter": "1.5.4",
    "protractor": "7.0.0",
    "ts-node": "9.1.1",
    "tslint": "5.20.1",
    "typescript": "^4.0.5"
  }
}
